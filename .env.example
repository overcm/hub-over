# Postgres — em dev local, gerado por `npx prisma dev --name hub-mentorias --detach`
DATABASE_URL="postgres://postgres:postgres@localhost:51214/hub_mentorias?sslmode=disable"

# Gerar com: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# https://resend.com — usado para enviar credenciais de acesso ao aluno
RESEND_API_KEY=""
EMAIL_FROM="Hub Over <onboarding@resend.dev>"

# local = upload direto no servidor (padrão) | bunny = Bunny.net Stream
VIDEO_PROVIDER="local"
VIDEO_LOCAL_PATH="./storage/videos"

# https://bunny.net/stream — opcional, só necessário se VIDEO_PROVIDER=bunny
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_PULL_ZONE=""

# local = disco local da VPS (padrão) | bunny = Bunny.net Storage
STORAGE_PROVIDER="local"

# Materiais complementares (PDFs etc.) — disco local, só usado se STORAGE_PROVIDER=local
MATERIALS_LOCAL_PATH="./storage/materials"
IMAGES_LOCAL_PATH="./storage/images"

# https://bunny.net/storage — opcional, só necessário se STORAGE_PROVIDER=bunny
# (necessário em produção sem disco persistente, ex: Vercel)
BUNNY_STORAGE_ZONE_NAME=""
BUNNY_STORAGE_PASSWORD=""
BUNNY_STORAGE_ENDPOINT="https://br.storage.bunnycdn.com"

# https://console.cloud.google.com/apis/credentials — OAuth Client ID (tipo "Web application")
# Redirect URI autorizado: <NEXTAUTH_URL>/api/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
